# .env.example - Variables de entorno requeridas para docfun-app
# Copia este archivo a .env y completa los valores

# --- Bot Teams (registrar bot nuevo en Azure AD) ---
BOT_APP_ID=
BOT_APP_SECRET=
BOT_TENANT_ID=

# --- Azure Cognitive Search (mismo índice que docfun-ingest) ---
AZURE_SEARCH_SERVICE=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=docfun-docs-idx

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_DEPLOYMENT_INTENT=gpt-4o-mini
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# --- REST /api/ask basic auth ---
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# --- URL base para mostrar enlaces navegables (opcional) ---
# Si la ingesta guardó rutas relativas, este prefijo se aplica al renderizar.
DOCFUN_BASE_URL=

# --- Tuning ---
MIN_SCORE_THRESHOLD_HYBRID=0.01
MIN_SCORE_THRESHOLD=10
RELEVANCE_THRESHOLD=0.5
PORT=8000
